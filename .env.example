# OpenAI-compatible API (LM Studio, OpenAI, etc.)
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small

# File storage
UPLOAD_DIR=/app/uploads

# Retrieval
RETRIEVAL_TOP_K=6
# Hybrid search weights (dense=embeddings, sparse=BM25) and RRF smoothing constant
HYBRID_DENSE_WEIGHT=0.7
HYBRID_SPARSE_WEIGHT=0.3
# Cosine distance cutoff: 2.0 = keep all dense results. Lower (e.g. 1.2) to exclude semantically distant docs.
HYBRID_MAX_DENSE_DISTANCE=2.0

# ChromaDB
CHROMA_DB_HOST=chromadb
CHROMA_DB_PORT=8000

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=documents

# MySQL
MYSQL_SERVER=db
MYSQL_PORT=3306
MYSQL_USER=ragwebui
MYSQL_PASSWORD=ragwebui
MYSQL_DATABASE=ragwebui

# JWT
SECRET_KEY=your-secret-key-here
